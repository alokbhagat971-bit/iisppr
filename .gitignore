```gitignore
# =========================
# Dependencies
# =========================
node_modules/
jspm_packages/

# =========================
# Build / Production
# =========================
dist/
build/
out/
.next/
.nuxt/
coverage/
*.tsbuildinfo

# =========================
# Logs
# =========================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# =========================
# Environment Variables
# =========================
.env
.env.*
!.env.example

# =========================
# Runtime files
# =========================
pids
*.pid
*.seed
*.pid.lock

# =========================
# Cache
# =========================
.cache/
.parcel-cache/
.eslintcache
.vite/
.tmp/
.temp/

# =========================
# OS generated files
# =========================
.DS_Store
Thumbs.db

# =========================
# IDE / Editor
# =========================
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp

# =========================
# Package manager files
# =========================
.pnpm-store/
.yarn/
.yarn-cache/
.yarnrc.yml

# =========================
# Testing
# =========================
coverage/
.nyc_output/

# =========================
# Misc
# =========================
*.local
vercel.json
.vercel/
firebase-debug.log
```
